# NEXUS — local environment (copy to .env.local and fill in)
# .env.local is git-ignored; this example is safe to commit.

# ── Autonomous agent sandbox (REQUIRED for the agent) ──────────────────
# Read server-side only. Use the "API Key" (e2b_...), NOT an access token.
# Get it at https://e2b.dev  → Dashboard → API Keys
E2B_API_KEY=

# ── Model providers ────────────────────────────────────────────────────
# You can also paste these directly in Settings instead of here.
# OpenRouter (100+ models): https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...
# NVIDIA NIM: https://build.nvidia.com
# NVIDIA_API_KEY=nvapi-...

# ── Optional: self-hosted API server (npm run api) ─────────────────────
# NEXUS_API_KEY=
# PORT=7860
